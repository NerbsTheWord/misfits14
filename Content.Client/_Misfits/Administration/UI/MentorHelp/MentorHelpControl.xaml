<!-- #Misfits Change - Mentor Help control XAML (like BwoinkControl but with limited verbs) -->
<Control
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls">
    <PanelContainer StyleClasses="BackgroundDark">
        <SplitContainer Orientation="Horizontal" VerticalExpand="True">
            <cc:PlayerListControl Access="Public" Name="ChannelSelector" HorizontalExpand="True" SizeFlagsStretchRatio="1" />
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" SizeFlagsStretchRatio="2">
                <!-- #Misfits Add — Ticket status bar shown above the chat area -->
                <BoxContainer Name="TicketStatusBar" Access="Public" Orientation="Horizontal" HorizontalExpand="True" Visible="False">
                    <RichTextLabel Name="TicketStatusLabel" Access="Public" HorizontalExpand="True" />
                    <Button Name="ClaimTicket" Access="Public" Text="{Loc 'ticket-system-claim-button'}" StyleClasses="OpenRight" Visible="True" />
                    <Button Name="UnclaimTicket" Access="Public" Text="{Loc 'ticket-system-unclaim-button'}" StyleClasses="OpenBoth" Visible="False" />
                    <Button Name="ResolveTicket" Access="Public" Text="{Loc 'ticket-system-resolve-button'}" StyleClasses="OpenBoth" Visible="True" />
                    <Button Name="ReopenTicket" Access="Public" Text="{Loc 'ticket-system-reopen-button'}" StyleClasses="OpenLeft" Visible="False" />
                </BoxContainer>
                <BoxContainer Access="Public" Name="MHelpArea" VerticalExpand="True" />
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <CheckBox Visible="True" Name="PlaySound" Access="Public" Text="Bwoink?" Pressed="True" />
                    <Control HorizontalExpand="True" MinWidth="5" />
                    <Button Visible="True" Name="PopOut" Access="Public" Text="Pop Out" StyleClasses="OpenBoth" HorizontalAlignment="Left" />
                    <Control HorizontalExpand="True" />
                    <Button Visible="False" Name="Notes" Text="Notes" StyleClasses="OpenBoth" />
                </BoxContainer>
            </BoxContainer>
        </SplitContainer>
    </PanelContainer>
</Control>
